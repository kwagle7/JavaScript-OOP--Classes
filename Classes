//--GETTERS AND SETTERS --//


class Drone {
    constructor(id){
        this._id = id;
    }
    
    //to get a property
   //to perform validation/logging and checking getter is used
   //looks id as a function, but not we can use it as property 
    get id(){
        console.log('in id getter');
        return this._id+ ' TEMPORARY';
    }
    //to set a property
    //to execute a function when we set a value
    // used for vaidation/error checking 
    set id(value){
        this._id =value;
    }
}

let drone = new Drone('A123');
drone.id='B456';
console.log('drone id: '+ drone.id);


//in id getter
//drone id: B456 TEMPORARY
