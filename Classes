//---Constructors and Properties Example in JavaScript OOP---//

class Drone {
    constructor(id,name){
            this.id=id;
            this.name=name;
    }

}

let drone = new Drone('420','Flyer');
console.log('drone:'+drone['id']+' '+drone['name']);
console.log('drone:'+drone.id+' '+drone.name);

// drone:420 Flyer
// drone:420 Flyer   -- Prints same results





//---Static Properties---//
class Drone {
    constructor(id,name){
            this.id=id;
            this.name=name;
    }
}


//setting static property or Class property
//here maxHeight is static property
Drone.maxHeight = 2000;

let drone = new Drone('A123','Flyer');
let drone2 = new Drone ('B456', 'Twirl');

console.log(Drone.maxHeight);
//prints 2000

console.log(drone.maxHeight);
//prints undefined




//---METHODS---//

class Drone {
    constructor(id,name){
            this.id=id;
            this.name=name;
    }
//lets define a method fly: Instance Method
    fly() {
    //we access the instance property by using this keyword
    console.log('Drone '+ this.id +' is flying.');
    }
}

let drone = new Drone('A123','Flyer');
let drone2 = new Drone ('B456', 'Twirl');

drone.fly();
//Drone A123 is flying.
drone2.fly();
//Drone B456 is flying.




